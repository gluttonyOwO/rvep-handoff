# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rvep?schema=public

# JWT (generate with: openssl rand -base64 32)
JWT_SIGNING_KEY=
JWT_REFRESH_KEY=

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Optional
BCRYPT_ROUNDS=12
NODE_ENV=development
CORS_ALLOWED_ORIGIN=http://localhost:3011
EDGE_INTERNAL_TOKEN=internal-dev-token
